{
  "name": "bug-hunter-replay",
  "version": "0.0.0",
  "description": "Playwright-based Web bug auto-exploration CLI.",
  "type": "module",
  "private": true,
  "packageManager": "pnpm@10.24.0",
  "bin": {
    "bug-hunter": "./dist/cli/index.js"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "lint": "eslint .",
    "format": "prettier --write .",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "dev": "tsx src/cli/index.ts",
    "demo-site": "tsx tests/fixtures/demo-site/server.ts"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "playwright": "^1.49.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/node": "^22.10.2",
    "eslint": "^9.17.0",
    "prettier": "^3.4.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.2",
    "vitest": "^2.1.8"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild"]
  }
}
